# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sducs_mk

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# AWS S3 (or Firebase Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=sducs-mk-storage
AWS_REGION=ap-south-1

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Fallback UPI
FALLBACK_UPI_ID=8940091624@naviaxis

# Encryption
AES_SECRET_KEY=your_32_char_aes_key_here_change_now

# Admin
ADMIN_EMAIL=admin@sducs.app
ADMIN_SECRET=your_admin_secret

# Frontend URL
FRONTEND_URL=http://localhost:3000
